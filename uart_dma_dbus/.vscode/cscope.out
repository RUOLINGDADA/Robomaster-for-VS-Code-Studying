(&(
mpu
->
RBAR
), &(
table
->RBAR), 
rowWordSize
);

311 
uint32_t
 
rnrBase
 = 
rnr
 & ~(
MPU_TYPE_RALIASES
-1U);

312 
uint32_t
 
rnrOffset
 = 
rnr
 % 
MPU_TYPE_RALIASES
;

314 
mpu
->
RNR
 = 
rnrBase
;

315 while ((
rnrOffset
 + 
cnt
) > 
MPU_TYPE_RALIASES
) {

316 
uint32_t
 
c
 = 
MPU_TYPE_RALIASES
 - 
rnrOffset
