589 if (
VoltageRange
 == 
FLASH_VOLTAGE_RANGE_1
)

591 
tmp_psize
 = 
FLASH_PSIZE_BYTE
;

593 else if (
VoltageRange
 == 
FLASH_VOLTAGE_RANGE_2
)

595 
tmp_psize
 = 
FLASH_PSIZE_HALF_WORD
;

597 else if (
VoltageRange
 == 
FLASH_VOLTAGE_RANGE_3
)

599 
tmp_psize
 = 
FLASH_PSIZE_WORD
;

603 
tmp_psize
 = 
FLASH_PSIZE_DOUBLE_WORD
;

607 if (
Sector
 > 
FLASH_SECTOR_11
)

