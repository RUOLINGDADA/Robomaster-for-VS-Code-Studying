(&(
mpu
->
RBAR
)+(
rnrOffset
*2U), &(
table
->RBAR), 
c
*
rowWordSize
);

318 
table
 += 
c
;

319 
cnt
 -= 
c
;

320 
rnrOffset
 = 0U;

321 
rnrBase
 += 
MPU_TYPE_RALIASES
;

322 
mpu
->
RNR
 = 
rnrBase
;

325 
	`ARM_MPU_OrderedMemcpy
(&(
mpu
->
RBAR
)+(
rnrOffset
*2U), &(
table
->RBAR), 
cnt
*
rowWordSize
);

327 
	}
}

