612 
	`CLEAR_BIT
(
FLASH
->
CR
, 
FLASH_CR_PSIZE
);

613 
FLASH
->
CR
 |= 
tmp_psize
;

614 
	`CLEAR_BIT
(
FLASH
->
CR
, 
FLASH_CR_SNB
);

615 
FLASH
->
CR
 |= 
FLASH_CR_SER
 | (
Sector
 << 
FLASH_CR_SNB_Pos
);

616 
FLASH
->
CR
 |= 
FLASH_CR_STRT
;

617 
	}
}

