541 
	`assert_param
(
	`IS_FLASH_BANK
(
Banks
));

544 
	`CLEAR_BIT
(
FLASH
->
CR
, 
FLASH_CR_PSIZE
);

546 if (
Banks
 == 
FLASH_BANK_BOTH
)

549 
FLASH
->
CR
 |= 
FLASH_MER_BIT
;

551 else if (
Banks
 == 
FLASH_BANK_1
)

554 
FLASH
->
CR
 |= 
FLASH_CR_MER1
;

559 
FLASH
->
CR
 |= 
FLASH_CR_MER2
;

561 
FLASH
->
CR
 |= 
FLASH_CR_STRT
 | ((
uint32_t
)
VoltageRange
 << 8U);

